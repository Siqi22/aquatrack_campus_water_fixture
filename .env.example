## Copy this file to `.env.local` (Vite loads it automatically) and fill in real values.
## Never commit `.env` or `.env.local`.
## Lovable / git-sync builds also read env/supabase.public.env (client-safe anon key only).

# Supabase → Project Settings → API
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# --- Vercel deploy: copy env/vercel.import.env.example → .env.vercel, fill values,
#     then Vercel Dashboard → Environment Variables → Import .env ---
# --- Label scan: ANTHROPIC_API_KEY on Vercel (NOT Supabase / Lovable) — see env/vercel.import.env.example ---

# Claude label scanning (Vercel Serverless API only — do NOT prefix with VITE_)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# Optional: full scan API URL for Capacitor builds (web uses /api/scan-fixture-label)
# VITE_SCAN_API_URL="https://your-app.vercel.app/api/scan-fixture-label"
# VITE_VERCEL_APP_URL="https://your-app.vercel.app"
