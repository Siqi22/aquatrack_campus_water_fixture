# Vercel 一键导入模板（复制为 .env.vercel 并填入真实值）
# Vercel → Settings → Environment Variables → Import .env → Redeploy
#
# VITE_* = 前端构建时注入
# ANTHROPIC_* = 仅 Vercel Serverless API 使用（不要加 VITE_ 前缀）

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Label scan — Claude Haiku via /api/scan-fixture-label (bypasses Lovable Cloud Edge Functions)
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: Capacitor / local Vite dev proxy to deployed Vercel API
# VITE_VERCEL_APP_URL=https://your-app.vercel.app
# VITE_SCAN_API_URL=https://your-app.vercel.app/api/scan-fixture-label
