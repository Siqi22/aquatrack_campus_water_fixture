## Vite env vars (example)
## Copy to `.env.local` (do not commit) and fill in real values.

# Mapbox GL public token (restrict allowed URLs in Mapbox dashboard)
VITE_MAPBOX_ACCESS_TOKEN=""

# Gemini (demo only; browser key is visible to users)
VITE_GEMINI_API_KEY=""
VITE_GEMINI_MODEL="gemini-3-flash-preview"

# Supabase (public URL + anon publishable key; still keep out of git in real projects)
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""

