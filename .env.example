## Copy this file to `.env.local` (Vite loads it automatically) and fill in real values.
## Never commit `.env` or `.env.local`.

# Supabase → Project Settings → API
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"

# Claude label scanning (server-side only — NOT VITE_ prefixed)
# Set the same values as Supabase Edge Function secrets, then deploy scan-fixture-label.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-haiku-20241022"
